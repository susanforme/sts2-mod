<Project Sdk="Godot.NET.Sdk/4.5.1">
  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <EnableDynamicLoading>true</EnableDynamicLoading>
    <RootNamespace>jhin</RootNamespace>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <NoWarn>STS001</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="tools/**/*.cs" />
    <Compile Remove=".godot/**/*.cs" />

    <Reference Include="0Harmony">
      <HintPath>lib\0Harmony.dll</HintPath>
      <Private>true</Private>
    </Reference>

    <Reference Include="sts2">
      <HintPath>lib\sts2.dll</HintPath>
      <Private>false</Private>
    </Reference>

    <Reference Include="GodotSharp">
      <HintPath>lib\Godot\GodotSharp.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Alchyr.Sts2.BaseLib" Version="3.1.0" />
    <PackageReference Include="Alchyr.Sts2.ModAnalyzers" Version="0.1.6" />
  </ItemGroup>

  <ItemGroup>
    <AdditionalFiles Include="JhinMod/localization/**/*.json" />
  </ItemGroup>
</Project>
